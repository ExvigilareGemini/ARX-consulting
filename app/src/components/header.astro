---
import styles from "./Header.module.scss";
import Logo from "../../public/images/logo.svg";

const navLinks = [
  { label: "Accueil", href: "/#hero" },
  { label: "Qui sommes-nous ?", href: "/#about" },
  { label: "Nos services", href: "/#services" },
  { label: "Contact", href: "/#contact" },
];
---

<header class={styles.header} id="site-header">
  <div class={styles.inner}>
    <a
      href="/#hero"
      id="logowrapper"
      class={styles.logowrapper}
      aria-label="ARX Consulting – Accueil"
    >
      <Logo />
      <div class={styles.logoTitleWrap}>
        <h2 class={styles.logoTitle}>ARX</h2>
        <h4 class={styles.logoSubTitle}>Consulting</h4>
      </div>
    </a>
    <nav class={styles.nav} aria-label="Navigation principale">
      {
        navLinks.map((link) => (
          <a href={link.href} class={styles.navLink}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <button
      class={styles.burger}
      id="burger-btn"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- Mobile drawer -->
    <nav
      class={styles.drawer}
      id="mobile-drawer"
      aria-label="Navigation mobile"
      aria-hidden="true"
    >
      {
        navLinks.map((link) => (
          <a href={link.href} class={styles.drawerLink} data-drawer-link>
            {link.label}
          </a>
        ))
      }
    </nav>

    <script>
      import { initHeader } from "../scripts/header.js";
      initHeader();
    </script>
  </div>
</header>
