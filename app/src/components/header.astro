---
import styles from './Header.module.scss';
import Logo from "../../public/images/logo.svg"

const navLinks = [
  { label: 'Accueil', href: '#hero' },
  { label: 'Qui sommes-nous ?', href: '#about' },
  { label: 'Nos services', href: '#services' },
  { label: 'Contact', href: '#contact' },
];
---

<header class={styles.header} id="site-header">
  <div class={styles.inner}>
    <a href="#hero" class={styles.logo} aria-label="ARX Consulting – Accueil">
      <!-- Logo placeholder : remplacer par votre SVG -->
      <Logo><Logo/>
      ARX Consulting
    </a>

    <nav class={styles.nav} aria-label="Navigation principale">
      {navLinks.map(link => (
        <a href={link.href} class={styles.navLink}>{link.label}</a>
      ))}
    </nav>

    <button
      class={styles.burger}
      id="burger-btn"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<nav
  class={styles.drawer}
  id="mobile-drawer"
  aria-label="Navigation mobile"
  aria-hidden="true"
>
  {navLinks.map(link => (
    <a href={link.href} class={styles.drawerLink} data-drawer-link>{link.label}</a>
  ))}
</nav>

<script>
  import { initHeader } from '../scripts/header.js';
  initHeader();
</script>
